PORT=3001
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/gymfit

# ── Gmail Email Notifications ─────────────────────────────────────
# How to get your App Password:
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification if not already on
#   3. Search "App passwords" → select "Mail" → Generate
#   4. Paste the 16-character password below (no spaces)
EMAIL_USER=rajangishor04@gmail.com
EMAIL_PASS=your_16_char_app_password_here
EMAIL_TO=rajangishor04@gmail.com

# ── JWT Auth ──────────────────────────────────────────────────────
# IMPORTANT: Change JWT_SECRET to a long random string in production!
JWT_SECRET=gymfit-super-secret-jwt-key-change-this-in-production-2024

# ── Frontend URL (for email links in verification/reset emails) ───
# Development: http://localhost:5173
# Production (GitHub Pages): https://YOUR_GITHUB_USERNAME.github.io/Gymfit
FRONTEND_URL=http://localhost:5173
